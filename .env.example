LOG_LEVEL=INFO
AUTO_REPLY_ENABLED=true
START_ADMIN_SERVER=true
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8765
XIANYU_ENABLED=true
SIMULATE_HUMAN_TYPING=false
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
MESSAGE_EXPIRE_MS=300000
AGENT_CORE_ENABLED=false
AGENT_CORE_TIMEOUT_MS=6000

# 默认不使用系统代理，避免本机代理配置错误导致闲鱼接口无法连接。
USE_SYSTEM_PROXY=false
XIANYU_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36

# 闲鱼网页登录态 Cookie，按 README 指引从浏览器复制完整 Cookie 后填入。
COOKIES_STR=

# 飞书群机器人 webhook，不使用飞书时可以先留空。
FEISHU_WEBHOOK=

# 独立 Agent+RAG 服务地址（启用 AGENT_CORE_ENABLED 时生效）
AGENT_CORE_BASE_URL=

# 先预留模型配置，首版默认不依赖模型 API。
API_KEY=
MODEL_BASE_URL=
MODEL_NAME=
